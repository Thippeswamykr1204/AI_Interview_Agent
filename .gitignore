# ---- Dependencies ----
node_modules/
frontend/node_modules/
backend/node_modules/

# ---- Environment variables (NEVER commit real keys) ----
.env
.env.local
.env.*.local
frontend/.env
frontend/.env.local
backend/.env
backend/.env.local
!.env.example
!backend/.env.example
!frontend/.env.example

# ---- Build output ----
dist/
build/
frontend/dist/
backend/dist/

# ---- Vite / bundler cache ----
.vite/
*.tsbuildinfo

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- App data (runtime-generated session files) ----
backend/src/data/sessions/*.json
!backend/src/data/sessions/.gitkeep

# ---- OS / editor junk ----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# ---- Coverage / test artifacts ----
coverage/
.nyc_output/